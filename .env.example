# ============================================================
# Dead Lead Follow-Up Automation - Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# --- GoHighLevel (GHL) ---
# Your GHL Sub-Account API Key (Settings > Integrations > API Keys)
GHL_API_KEY=your_ghl_api_key_here
# Your GHL Sub-Account Location ID (visible in the URL when logged in)
GHL_LOCATION_ID=your_ghl_location_id_here
# Comma-separated pipeline stage IDs for "dead leads" (e.g., Closed Lost, No Show)
# Find these in GHL > Opportunities > Pipeline Settings
GHL_DEAD_PIPELINE_STAGE_IDS=stage_id_1,stage_id_2
# Minimum days since last activity to qualify as a dead lead
GHL_INACTIVITY_DAYS=14

# --- Fireflies.ai ---
# Your Fireflies API Key (app.fireflies.ai > Integrations > API)
FIREFLIES_API_KEY=your_fireflies_api_key_here

# --- Slack ---
# Slack Bot Token (starts with xoxb-)
# Create at api.slack.com/apps > Your App > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# The Slack channel ID where draft emails will be posted for approval
# Right-click the channel in Slack > View channel details > Copy channel ID
SLACK_CHANNEL_ID=C0XXXXXXXXX
# Slack Signing Secret (api.slack.com/apps > Your App > Basic Information)
SLACK_SIGNING_SECRET=your_slack_signing_secret

# --- Gmail (Google Workspace) ---
# Path to your Google OAuth credentials JSON file
# Download from Google Cloud Console > APIs & Services > Credentials
GMAIL_CREDENTIALS_FILE=credentials.json
# The Gmail address to send emails FROM
GMAIL_SENDER_EMAIL=you@yourdomain.com

# --- OpenAI ---
# Your OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
# Model to use for email generation
OPENAI_MODEL=gpt-4o

# --- App Settings ---
# Timezone for the scheduler
SCHEDULER_TIMEZONE=America/New_York
# Port for the FastAPI server (must be publicly accessible for Slack webhooks)
APP_PORT=8000
