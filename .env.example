# ============================================================
# Dead Lead Follow-Up Automation - Environment Variables
# Set these in Railway (or your deployment platform) as env vars
# DO NOT commit actual credentials - use Railway's env var settings
# ============================================================

# --- GoHighLevel (GHL) ---
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_INACTIVITY_DAYS=30

# --- Fireflies.ai ---
FIREFLIES_API_KEY=your_fireflies_api_key_here

# --- Calendly ---
CALENDLY_TOKEN=your_calendly_pat_token_here
CALENDLY_USER_UUID=your_calendly_user_uuid_here
CALENDLY_BOOKING_LINK=https://calendly.com/your-link

# --- Typeform ---
TYPEFORM_API_TOKEN=your_typeform_api_token_here
TYPEFORM_FORM_ID=your_typeform_form_id_here

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_SIGNING_SECRET=your_slack_signing_secret

# --- Gmail OAuth (use refresh token - no file needed) ---
# Get these from Google Cloud Console > APIs & Services > Credentials
GMAIL_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_SENDER_EMAIL=you@yourdomain.com

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# --- App Settings ---
SCHEDULER_TIMEZONE=America/New_York
PORT=8000
